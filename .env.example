# ──────────────────────────────────────────────────────────────────────────────
# ZY Steel HR Dashboard — Environment Variables
# Copy to .env.local for local development.
# ALL variables marked [required] must be set before starting the server.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# [required] PostgreSQL connection string.
# Production: use an HTTP/WS-compatible driver (Neon, Prisma Accelerate) for
# edge deployment — see docs/architecture.md §3.4.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/zysteel_hr?schema=public"

# ── Authentication (Better Auth) ──────────────────────────────────────────────
# [required] 32-byte random secret used to sign session tokens.
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-a-32-byte-random-string"

# [required] The canonical base URL of the application.
# Must match the domain where the app is deployed (no trailing slash).
AUTH_URL="http://localhost:3000"

# ── Scheduled Jobs ────────────────────────────────────────────────────────────
# [required] Shared secret sent in x-cron-secret header by the cron scheduler.
# All /api/cron/* endpoints reject requests without this value.
# Generate: openssl rand -hex 32
CRON_SECRET="generate-a-64-char-hex-string"

# ── Telegram Notifications ────────────────────────────────────────────────────
# [optional] Bot token from @BotFather. Leave empty to disable Telegram alerts.
TELEGRAM_BOT_TOKEN=""

# [optional] Chat/channel ID to send alerts to (e.g., "-1001234567890").
TELEGRAM_CHAT_ID=""

# ── AI Assistant ──────────────────────────────────────────────────────────────
# [optional] Anthropic API key for the AI HR/Production/Sales assistant.
# Leave empty to disable AI features (pages show "not configured" message).
ANTHROPIC_API_KEY=""

# ── Cloudflare (production only) ──────────────────────────────────────────────
# R2 object storage for employee documents (replaces /public/uploads/ on edge).
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="zysteel-documents"

# Turnstile CSRF protection on the login page.
TURNSTILE_SECRET_KEY=""

# Public URL for sitemap and absolute link generation.
NEXT_PUBLIC_APP_URL="https://hr.zysteel.com"
